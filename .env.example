# Backend API Keys
GITHUB_TOKEN=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
GITHUB_MODEL=gpt-4o
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Script generation provider (default: free/local Ollama)
# Values: ollama | gemini
SCRIPT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct

# App Security
SECRET_KEY=your_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here

# Database (PostgreSQL)
# For production, use DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/scripty_prod

# For development
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scripty_dev

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Service (SendGrid, Resend, etc.)
EMAIL_SERVICE_API_KEY=
EMAIL_FROM=noreply@scripty.app

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Redis (Cache) - Optional
REDIS_URL=redis://localhost:6379/0

# Flask
FLASK_DEBUG=0
PORT=5000

# Vidéo IA (Docker Compose définit LTX_RUNNER_URL vers le service ltx-runner)
# LTX_MOCK=1 : démo sans GPU (ffmpeg). LTX_MOCK=0 : vrai LTX-2 (checkpoints + GPU requis)
LTX_MOCK=1
LTX_RUNNER_TOKEN=
# Chemins réels si LTX_MOCK=0 (voir ltx_runner/app.py)
# LTX_CHECKPOINT_PATH=
# LTX_DISTILLED_LORA_PATH=
# LTX_SPATIAL_UPSCALER_PATH=
# LTX_GEMMA_ROOT=
# LTX_PYTHON=/ltx/.venv/bin/python
